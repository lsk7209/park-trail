{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/us-trails/Blog",
      "destination": "https://gradienttrail.com/blog/",
      "permanent": true
    },
    {
      "source": "/us-trails/Blog.html",
      "destination": "https://gradienttrail.com/blog/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.gradienttrail.com"
        }
      ],
      "destination": "https://gradienttrail.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/us-trails/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
